# ─────────────────────────────────────────────────────────────────────────────
# .env.example - Fantasy LNB Backend
# ─────────────────────────────────────────────────────────────────────────────
# 
# INSTRUCCIONES:
# 1. Copia este archivo a .env: cp .env.example .env
# 2. Completa los valores con tus datos
# 3. ⚠️ NUNCA subas .env a GitHub - está en .gitignore
# 4. Comparte solo este archivo .env.example con otros desarrolladores
#
# ─────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────
# Base de Datos - PostgreSQL
# ────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grancoach_lnb
DB_USER=postgres
DB_PASSWORD=tu_password_postgres_aqui


# ────────────────────────────────────────────────────────────────────────────
# Autenticación JWT
# ────────────────────────────────────────────────────────────────────────────
# Generar un secreto aleatorio fuerte:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_aleatorio_muy_largo_de_32_caracteres_minimo_aqui
JWT_EXPIRES_IN=7d


# ────────────────────────────────────────────────────────────────────────────
# Servidor Express
# ────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development


# ────────────────────────────────────────────────────────────────────────────
# Seguridad - Bcrypt
# ────────────────────────────────────────────────────────────────────────────
# Número de rounds para hash de contraseñas (10-12 es estándar)
BCRYPT_ROUNDS=12


# ────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ────────────────────────────────────────────────────────────────────────────
# Ventana de tiempo en milisegundos (900000 = 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Máximo número de requests por ventana
RATE_LIMIT_MAX=100


# ────────────────────────────────────────────────────────────────────────────
# CORS - Control de Origen (Frontend)
# ────────────────────────────────────────────────────────────────────────────
# URL del frontend (durante desarrollo: http://localhost:5173 o 3000)
CORS_ORIGIN=http://localhost:5173


# ────────────────────────────────────────────────────────────────────────────
# API Basketball (api-basketball.com / api-sports.io)
# ────────────────────────────────────────────────────────────────────────────
# Obtener en: https://dashboard.api-sports.io/register
# Plan gratuito: 100 requests/día
API_BASKETBALL_KEY=tu_api_key_aqui
API_BASKETBALL_URL=https://v1.basketball.api-sports.io
API_BASKETBALL_LEAGUE_ID=18
API_BASKETBALL_SEASON=2024-2025


# ────────────────────────────────────────────────────────────────────────────
# Email - Notificaciones a Usuarios (Mailtrap SMTP)
# ────────────────────────────────────────────────────────────────────────────
# Habilitar/deshabilitar envío de emails
EMAILS_ENABLED=false

# Configuración SMTP — Mailtrap Email Sending
# Docs oficiales: https://docs.mailtrap.io/email-api-smtp/setup/smtp-integration
#
# Pasos para obtener credenciales:
# 1. Crear cuenta en https://mailtrap.io
# 2. Ir a "Sending Domains" > tu dominio verificado > pestaña "Integrations" > "SMTP"
# 3. Copiar el API token generado (campo SMTP_PASS)
# 4. SMTP_USER es siempre "api" (fijo, no cambia)
#
# Nota: puerto 587 usa STARTTLS (requerido por Mailtrap). Puerto 465 usa SSL directo.
SMTP_HOST=live.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=api
SMTP_PASS=tu_mailtrap_api_token_aqui
SMTP_FROM="Gran Coach LNB <noreply@tu-dominio-verificado.com>"


# ────────────────────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_FILE=logs/app.log


# ────────────────────────────────────────────────────────────────────────────
# Admin Defaults (Para desarrollo)
# ────────────────────────────────────────────────────────────────────────────
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=admin_password_inicial


# ────────────────────────────────────────────────────────────────────────────
# URLs Externas
# ────────────────────────────────────────────────────────────────────────────
# URL del frontend (usado en links de emails)
FRONTEND_URL=http://localhost:3000
# API_URL=http://localhost:3000


# ────────────────────────────────────────────────────────────────────────────
# Notas de Seguridad
# ────────────────────────────────────────────────────────────────────────────
# 
# IMPORTANTE:
# - Los valores aquí NO son reales (son ejemplos/placeholders)
# - El archivo .env REAL debe estar en .gitignore ✓
# - Usa secretos/credenciales fuertes en producción
# - Para generar JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - En producción: usar variables de entorno desde el hosting/CI-CD (no archivo .env)
# - Revisar regularmente qué archivos se suben a GitHub
#
# ────────────────────────────────────────────────────────────────────────────
