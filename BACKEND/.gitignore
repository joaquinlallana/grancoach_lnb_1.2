# ─────────────────────────────────────────────────────────────────────────────
# .gitignore - Fantasy LNB Backend
# Protege archivos sensibles y no necesarios en el repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────
# Dependencias
# ────────────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml


# ────────────────────────────────────────────────────────────────────────────
# Archivos de Configuración Sensibles
# ────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# ⚠️ CRÍTICO: Nunca subir credenciales, contraseñas, API keys, JWT_SECRET, DB credentials
# Si por accidente subes credenciales, revoca inmediatamente en GitHub


# ────────────────────────────────────────────────────────────────────────────
# Base de Datos (Backups y Dumps)
# ────────────────────────────────────────────────────────────────────────────
*.sql
*.dump
*.backup
*.bak
db/
data/
postgres/


# ────────────────────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
.pnpm-debug.log*
*-debug.log
*-error.log


# ────────────────────────────────────────────────────────────────────────────
# Tests y Coverage
# ────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
*.info
test-results/
junit.xml


# ────────────────────────────────────────────────────────────────────────────
# Build y Outputs
# ────────────────────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo
out/


# ────────────────────────────────────────────────────────────────────────────
# IDE y Editor Settings (Personales)
# ────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace
.eslintignore
.prettierignore
.editorconfig


# ────────────────────────────────────────────────────────────────────────────
# Sistema Operativo
# ────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini
Thumbs.db
*.cab
*.lnk


# ────────────────────────────────────────────────────────────────────────────
# Archivos Temporales
# ────────────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
.cache/
.turbo/


# ────────────────────────────────────────────────────────────────────────────
# Herramientas de Desarrollo
# ────────────────────────────────────────────────────────────────────────────
.next/
.nuxt/
dist
dist/
.cache/
.parcel-cache
.eslintcache
.node_repl_history
.claud/


# ────────────────────────────────────────────────────────────────────────────
# VS Code
# ────────────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace


# ────────────────────────────────────────────────────────────────────────────
# Git
# ────────────────────────────────────────────────────────────────────────────
.git/
.gitmodules


# ────────────────────────────────────────────────────────────────────────────
# Debugging
